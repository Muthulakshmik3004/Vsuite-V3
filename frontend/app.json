{
  "expo": {
    "name": "EmployeeApp",
    "slug": "EmployeeApp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/whatsapp5.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,

    "splash": {
      "image": "./assets/whatsapp5.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to verify you are at the office for attendance.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use your location to verify you are at the office for attendance."
      }
    },

    "android": {
      "package": "com.vienstereoptic.EmployeeApp",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/whatsapp5.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true
    },

    "web": {
      "favicon": "./assets/whatsapp5.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-asset"
    ],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ae973aa-d4bf-4c46-bc90-3e9bb33d9288"
      }
    },

    "owner": "lakshaa"
  }
}
